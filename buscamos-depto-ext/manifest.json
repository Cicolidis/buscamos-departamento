{
  "manifest_version": 3,
  "name": "Enviar a Buscamos Depto",
  "version": "1.1",
  "description": "Agrega un botón en ZonaProp para enviar el aviso a cicolidis.github.io/buscamos-departamento",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://www.zonaprop.com.ar/*",
    "https://cicolidis.github.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zonaprop.com.ar/propiedades/clasificado/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://cicolidis.github.io/buscamos-departamento/*"],
      "js": ["inject.js"],
      "run_at": "document_idle"
    }
  ]
}